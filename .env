# ==================== ENVIRONMENT ====================
NODE_ENV=development
PORT=5000
API_VERSION=v1
LOG_LEVEL=debug

# ==================== DATABASES ====================
MONGODB_URI=mongodb://localhost:27017/changex
MONGODB_URI_TEST=mongodb://localhost:27017/changex_test
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ==================== JWT AUTHENTICATION ====================
JWT_SECRET=super_secret_jwt_key_please_change_in_production_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=super_secret_refresh_key_please_change_in_production_min_64_chars
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=changex-academy

# ==================== OAUTH ====================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ==================== CLOUDINARY ====================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=changex

# ==================== PAYSTACK ====================
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
PAYSTACK_CALLBACK_URL=https://api.changex.academy/api/v1/payments/paystack/callback
PAYSTACK_SPLIT_CODE=SP_xxxxxxxxxxxx

# ==================== EMAIL (SMTP) ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=ChangeX Academy
SMTP_FROM_EMAIL=noreply@changex.academy

# ==================== FIREBASE ====================
FIREBASE_PROJECT_ID=changex-academy
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@changex-academy.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://changex-academy.firebaseio.com

# ==================== OPENAI ====================
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=2000

# ==================== STRIPE (FALLBACK) ====================
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx

# ==================== FRONTEND ====================
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:5000

# ==================== ADMIN ====================
ADMIN_EMAIL=admin@changex.academy
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FIRST_NAME=Super
ADMIN_LAST_NAME=Admin

# ==================== RATE LIMITING ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# ==================== AFFILIATE & REFERRAL ====================
AFFILIATE_COMMISSION_DEFAULT=15
REFERRAL_BONUS_AMOUNT=500
MIN_PAYOUT_AMOUNT=5000
REVENUE_SPLIT_INSTRUCTOR=80
REVENUE_SPLIT_PLATFORM=20

# ==================== SECURITY ====================
BCRYPT_SALT_ROUNDS=12
ENCRYPTION_KEY=your_32_byte_encryption_key_here_min_32_chars
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
SESSION_SECRET=your_session_secret_min_32_chars

# ==================== FEATURES ====================
ENABLE_AI_TUTOR=true
ENABLE_GAMIFICATION=true
ENABLE_CERTIFICATES=true
ENABLE_AFFILIATE=true
ENABLE_LIVE_CLASSES=false
MAINTENANCE_MODE=false

# ==================== MONITORING ====================
SENTRY_DSN=your_sentry_dsn
NEW_RELIC_LICENSE_KEY=your_new_relic_key
APM_SERVICE_NAME=changex-api

# ==================== CACHE ====================
CACHE_TTL_COURSES=3600
CACHE_TTL_USER=1800
CACHE_TTL_LEADERBOARD=300
